# Rekomendasi development: pakai proxy Vite agar frontend tetap request ke /api.
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Contoh lain yang didukung:
# VITE_API_URL=https://backend.example.com
# VITE_API_URL=https://backend.example.com/api
# VITE_API_URL=backend.example.com/api
