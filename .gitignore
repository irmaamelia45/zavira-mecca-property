# Root gitignore for monorepo (frontend + backend)

# Dependencies
node_modules/
frontend/node_modules/
backend/vendor/

# Build artifacts
frontend/dist/
frontend/dist-ssr/
backend/public/build/
backend/public/hot

# Runtime logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and secrets
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
frontend/*.local
backend/.env
backend/.env.*
!backend/.env.example
backend/auth.json

# User-generated/uploaded files
backend/public/uploads/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
