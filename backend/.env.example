# Production environment template for Zavira Mecca Property.
# Copy to backend/.env on the production server, fill every placeholder,
# run "php artisan key:generate", and never commit real credentials.

APP_NAME="Zavira Mecca Property"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com
FRONTEND_URL=https://www.example.com
CORS_ALLOWED_ORIGINS=https://www.example.com
SANCTUM_STATEFUL_DOMAINS=www.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database: create a dedicated production database user with minimum privileges.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=production_database_name
DB_USERNAME=production_database_user
DB_PASSWORD=change_me_database_password

CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SANCTUM_EXPIRATION=60

# Superadmin seeder: set a strong unique password only on the production server.
SUPERADMIN_NAME="Super Admin"
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PHONE=6281234567890
SUPERADMIN_PASSWORD=change_me_strong_superadmin_password
SUPERADMIN_ADDRESS="Kantor Zavira Mecca"

# Mail provider credentials.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mail_username
MAIL_PASSWORD=change_me_mail_password
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp/Fonnte integration.
WHATSAPP_ENABLED=false
OFFICE_MAPS_LINK=https://maps.example.com/office
FONNTE_BASE_URL=https://api.fonnte.com
FONNTE_TOKEN=change_me_fonnte_token
FONNTE_TIMEOUT=20
FONNTE_CONNECT_ONLY=true

# Cloudflare R2 private bucket credentials. Do not make sensitive backups public.
R2_ACCESS_KEY_ID=change_me_r2_access_key_id
R2_SECRET_ACCESS_KEY=change_me_r2_secret_access_key
R2_ACCOUNT_ID=change_me_r2_account_id
R2_BUCKET=change_me_private_bucket
R2_ENDPOINT=https://change_me_r2_account_id.r2.cloudflarestorage.com
R2_REGION=auto
R2_USE_PATH_STYLE_ENDPOINT=true
R2_URL=
BACKUP_R2_DISK=r2

# Automatic database backup to Cloudflare R2.
# Requires mysqldump on the server and Laravel scheduler to be active.
DATABASE_BACKUP_ENABLED=true
DATABASE_BACKUP_CONNECTION=mysql
DATABASE_BACKUP_DISK=r2
DATABASE_BACKUP_PREFIX=database
DATABASE_BACKUP_MYSQLDUMP_PATH=mysqldump
DATABASE_BACKUP_TMP_PATH=
DATABASE_BACKUP_TIMEOUT=900
DATABASE_BACKUP_SCHEDULE_AT=00:30
DATABASE_BACKUP_DAILY_RETENTION_DAYS=30
DATABASE_BACKUP_WEEKLY_RETENTION_WEEKS=8
DATABASE_BACKUP_MONTHLY_RETENTION_MONTHS=12

# Sensitive booking documents stay in private local storage, then backup to R2.
# Requires queue worker to process the document-backups queue.
DOCUMENT_STORAGE_DISK=local
DOCUMENT_BACKUP_ENABLED=true
DOCUMENT_BACKUP_PROVIDER=r2
DOCUMENT_BACKUP_DISK=r2
DOCUMENT_BACKUP_PREFIX=documents
DOCUMENT_BACKUP_QUEUE=document-backups
DOCUMENT_BACKUP_BATCH_LIMIT=250
DOCUMENT_RETENTION_COMPLETED_DAYS=180
DOCUMENT_RETENTION_REJECTED_DAYS=90
DOCUMENT_RETENTION_CANCELED_DAYS=90

ENABLE_DUMMY_SEEDERS=false
VITE_APP_NAME="${APP_NAME}"
